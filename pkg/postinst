#!/bin/sh
set -e

case "$1" in
    configure|triggered)
        # Grant the binary the right to bind to privileged ports (< 1024)
        # without requiring it to run as root for the whole process lifetime.
        # This is re-applied on every upgrade because package installation
        # replaces the binary and clears any previous file capabilities.
        if command -v setcap > /dev/null 2>&1; then
            setcap cap_net_bind_service=ep /usr/sbin/pwldapd
        else
            echo "pwldapd: setcap not found (install libcap2-bin)." >&2
            echo "         The daemon will not be able to bind to port 389" >&2
            echo "         unless it runs as root or a redirect is configured." >&2
        fi
        ;;
esac

